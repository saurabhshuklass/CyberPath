<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:paddingTop="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ================= HEADER ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/login_card_bg"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/accent_blue" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URL Safety Checker"
                    android:textColor="@color/text_white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detect malicious and phishing URLs"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ================= DESCRIPTION ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cyber criminals often use fake websites to steal passwords, banking information and personal data. Analyze any URL before opening it."
                android:textColor="@color/text_gray"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>


        <!-- ================= URL ANALYZER ================= -->

        <LinearLayout
            android:id="@+id/cardAnalyzer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍 Analyze URL"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Paste any website URL below to check whether it is safe, suspicious or potentially malicious."
                android:textColor="@color/text_gray"
                android:textSize="15sp"/>

            <!-- URL Input -->

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/urlInputLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:boxBackgroundColor="@color/bg_dark"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/accent_blue"
                app:startIconTint="@color/accent_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://example.com"
                    android:inputType="textUri"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_gray"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Scan Button -->

            <Button
                android:id="@+id/btnAnalyze"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_login_bg"
                android:text="Scan URL"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>

            <!-- Loading -->

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="18dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- ================= HOW IT WORKS ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡 How It Works"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="CyberPath performs rule-based URL analysis and can optionally verify websites using Google Safe Browsing for additional protection."
                android:textColor="@color/text_gray"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="✔ HTTPS Verification"
                android:textColor="@color/accent_blue"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ URL Structure Analysis"
                android:textColor="@color/accent_blue"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ Suspicious Keyword Detection"
                android:textColor="@color/accent_blue"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ Google Safe Browsing Support"
                android:textColor="@color/accent_blue"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ================= RESULT CARD ================= -->

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan Result"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtVerdict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="SAFE"
                android:textColor="#00E676"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtRiskScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Risk Score : 0%"
                android:textColor="@color/text_gray"
                android:textSize="16sp"/>

            <ProgressBar
                android:id="@+id/riskProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="16dp"
                android:max="100"
                android:progress="0"/>

            <!-- Security Checks -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Security Checks"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtHttps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="✔ HTTPS"
                android:textColor="#00E676"/>

            <TextView
                android:id="@+id/txtShortener"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ URL Shortener"
                android:textColor="#00E676"/>

            <TextView
                android:id="@+id/txtIp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ IP Address"
                android:textColor="#00E676"/>

            <TextView
                android:id="@+id/txtKeyword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ Suspicious Keywords"
                android:textColor="#00E676"/>

            <TextView
                android:id="@+id/txtLength"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ URL Length"
                android:textColor="#00E676"/>

            <!-- Recommendation -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Recommendation"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtRecommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:text="Recommendations will appear here after scanning."
                android:textColor="@color/text_gray"
                android:textSize="15sp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>