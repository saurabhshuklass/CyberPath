<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08142A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ================= HEADER ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/login_card_bg"
                android:padding="12dp"
                android:src="@drawable/back"
                app:tint="#35CFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quiz Center"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test your cybersecurity knowledge"
                    android:textColor="#8BA3D0"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ================= STATISTICS ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:background="@drawable/login_card_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="20dp"
            android:weightSum="3">

            <!-- Best Score -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtBestScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#35CFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best Score"
                    android:textColor="#BFC6D8"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Divider -->

            <View
                android:layout_width="1dp"
                android:layout_height="45dp"
                android:background="#20385E" />

            <!-- Quiz Count -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtQuizCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#35CFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quizzes"
                    android:textColor="#BFC6D8"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Divider -->

            <View
                android:layout_width="1dp"
                android:layout_height="45dp"
                android:background="#20385E" />

            <!-- Rank -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#--"
                    android:textColor="#35CFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rank"
                    android:textColor="#BFC6D8"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ================= BEGINNER QUIZ ================= -->

        <!-- ================= BEGINNER QUIZ ================= -->

        <LinearLayout
            android:id="@+id/cardBeginner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🟢 BEGINNER"
                    android:textColor="#00E676"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 Questions"
                    android:textColor="#BFC6D8"
                    android:textSize="13sp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Learn cybersecurity fundamentals and build a strong foundation."
                android:textColor="#BFC6D8"
                android:textSize="15sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="50 Questions • 10 Random • 10 Minutes"
                android:textColor="#35CFFF"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="CIA Triad"
                    android:textColor="#00E676"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Basic Threats"
                    android:textColor="#00E676"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Password"
                    android:textColor="#00E676"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnBeginner"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_login_bg"
                android:text="Start Beginner Quiz"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ================= INTERMEDIATE QUIZ ================= -->

        <!-- ================= INTERMEDIATE QUIZ ================= -->

        <LinearLayout
            android:id="@+id/cardIntermediate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🟡 INTERMEDIATE"
                    android:textColor="#FFD54F"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 Questions"
                    android:textColor="#BFC6D8"
                    android:textSize="13sp"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Network security, phishing attacks and malware detection."
                android:textColor="#BFC6D8"
                android:textSize="15sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="50 Questions • 10 Random • 12 Minutes"
                android:textColor="#35CFFF"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Network"
                    android:textColor="#FFD54F"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Phishing"
                    android:textColor="#FFD54F"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Malware"
                    android:textColor="#FFD54F"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnIntermediate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_login_bg"
                android:text="Start Intermediate Quiz"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ================= ADVANCED QUIZ ================= -->

        <!-- ================= ADVANCED QUIZ ================= -->

        <LinearLayout
            android:id="@+id/cardAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔴 ADVANCED"
                    android:textColor="#FF6B6B"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50 Questions"
                    android:textColor="#BFC6D8"
                    android:textSize="13sp"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Social engineering, safe browsing and advanced cyber attacks."
                android:textColor="#BFC6D8"
                android:textSize="15sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="50 Questions • 10 Random • 15 Minutes"
                android:textColor="#35CFFF"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Social Eng."
                    android:textColor="#FF6B6B"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Safe Browsing"
                    android:textColor="#FF6B6B"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/topic_chip_bg"
                    android:padding="6dp"
                    android:text="Mixed"
                    android:textColor="#FF6B6B"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnAdvanced"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_login_bg"
                android:text="Start Advanced Quiz"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>