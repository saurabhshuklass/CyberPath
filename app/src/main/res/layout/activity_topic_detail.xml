<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08142A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Topic Image -->

        <ImageView
            android:id="@+id/imgTopic"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:scaleType="centerCrop"
            android:src="@drawable/topic_intro"
            android:background="@drawable/login_card_bg"/>

        <!-- Title -->

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Introduction to Cyber Security"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginTop="20dp"/>

        <!-- Notes Heading -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Notes"
            android:textColor="#35CFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="15dp"/>

        <!-- Notes Card -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/txtContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"/>

        </LinearLayout>

        <!-- Open PDF Button -->

        <Button
            android:id="@+id/btnOpenPdf"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="📄 Open PDF Notes"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_login_bg"
            android:layout_marginTop="20dp"/>

        <!-- Complete Button -->

        <Button
            android:id="@+id/btnComplete"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="✓ Mark as Completed"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_login_bg"
            android:layout_marginTop="15dp"/>

    </LinearLayout>

</ScrollView>